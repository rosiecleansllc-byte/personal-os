# Railway provides DATABASE_URL automatically when the Postgres addon is attached.
DATABASE_URL=postgresql://user:pass@host:5432/personal_os

# Bearer key for programmatic writes (Zapier, n8n, routines). Generate a long random string.
API_KEY=

# Output of: npm run hash-password -- "your-ui-password"
UI_PASSWORD_HASH=

# Set to true only if your Postgres connection requires SSL (e.g. Railway public proxy URL).
# The internal Railway DATABASE_URL does not need it.
DATABASE_SSL=false
